{
  "name": "javavisualizer",
  "displayName": "JavaVisualizer",
  "description": "Live JavaFX UI preview inside VS Code. See and interact with your Java desktop app in real-time.",
  "version": "0.0.1",
  "publisher": "SourisCG",
  "license": "MIT",
  "icon": "resources/icons/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SourisCG/JavaVisualizer"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "java",
    "javafx",
    "swing",
    "preview",
    "live preview",
    "hot reload",
    "desktop",
    "ui"
  ],
  "activationEvents": [
    "onCommand:javavisualizer.openPreview",
    "onCommand:javavisualizer.refresh",
    "onCommand:javavisualizer.runDesktop",
    "workspaceContains:**/*.java"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "javavisualizer.openPreview",
        "title": "JavaVisualizer: Open Preview",
        "icon": "$(play)"
      },
      {
        "command": "javavisualizer.refresh",
        "title": "JavaVisualizer: Refresh Preview",
        "icon": "$(refresh)"
      },
      {
        "command": "javavisualizer.runDesktop",
        "title": "JavaVisualizer: Run on Desktop",
        "icon": "$(open-preview)"
      }
    ],
    "configuration": {
      "title": "JavaVisualizer",
      "properties": {
        "javavisualizer.autoReload": {
          "type": "boolean",
          "default": false,
          "description": "Automatically recompile and refresh preview when a .java file is saved."
        },
        "javavisualizer.frameRate": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 60,
          "description": "Target FPS for the preview stream."
        },
        "javavisualizer.jpegQuality": {
          "type": "number",
          "default": 75,
          "minimum": 10,
          "maximum": 100,
          "description": "JPEG quality for frame compression (1-100)."
        },
        "javavisualizer.javaHome": {
          "type": "string",
          "default": "",
          "description": "Custom path to JDK. Leave empty to auto-detect from JAVA_HOME or PATH."
        },
        "javavisualizer.mainClass": {
          "type": "string",
          "default": "",
          "description": "Main class to run. Leave empty for auto-detection."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run compile:ts && npm run compile:agent",
    "compile:ts": "webpack",
    "compile:agent": "cd agent && ./gradlew shadowJar && cp build/libs/JavaVisualizerAgent.jar ../resources/",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "build:vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.22.0",
    "eslint": "^8.56.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
